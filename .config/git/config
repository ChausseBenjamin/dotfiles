[user]
name = Benjamin Chausse
email = benjamin@chausse.dev
	signingkey = /home/master/.ssh/id_ed25519
[init]
	defaultBranch = master
[push]
	autoSetupRemote = true
[pull]
	rebase = false
[commit]
	gpgSign = true
[tag]
	gpgsign = true
[sendemail]
	smtpserver = mail.chausse.xyz
	smtpuser = benjamin
	smtpserverport = 587
	smtpencryption = tls
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[safe]
	directory = /home/master/.local/src/river
[url "git@github.com:"]
	insteadOf = https://github.com/
; [core]
; 	pager = delta
; [interactive]
; 	diffFilter = delta --color-only
[delta]
	navigate = true
[merge]
	conflictStyle = zdiff3
[gpg]
	format = ssh
