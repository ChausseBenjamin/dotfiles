# Window
# window-decoration = client
window-theme = dark
resize-overlay = never
confirm-close-surface = false

shell-integration-features = ssh-env,ssh-terminfo,cursor

custom-shader = shaders/cursor_warp.glsl

# macOS
macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden
macos-option-as-alt = true
macos-icon = official

# linux weirdness
window-decoration = none
window-padding-color = extend
window-padding-x = 0
window-padding-y = 0

# Performance enhancements
quit-after-last-window-closed = true
quit-after-last-window-closed-delay = 5m

# Kitty Images
image-storage-limit = 3200000000

# Mouse
mouse-hide-while-typing = true

# Keybinds
keybind = alt+shift+k=increase_font_size:1
keybind = alt+shift+j=decrease_font_size:1
keybind = super+shift+c=copy_to_clipboard
keybind = super+shift+v=paste_from_clipboard

# Clipboard
clipboard-read = allow
clipboard-write = allow
copy-on-select = true

# Background and Transparency
background-opacity = 0.83
unfocused-split-opacity = 06
background-blur = true
background-blur-radius = 15

theme = Vague
# theme = Ghostty Default Style Dark
background = #111a1f
selection-background=#405065
selection-foreground=#CDCDCD

# Fonts and Cursor
font-family = "Vulf Mono"
font-size = 17

cursor-style = block
cursor-color = #90a0b5
cursor-opacity = 0.8

