#!/bin/sh

[ -z "$1" ] && col=$(hyprpicker -an ) ||
  col="$1"

svg="<svg width=\"64\" height=\"64\"><circle cx=\"32\" cy=\"32\" r=\"30\" fill=\"$col\"/></svg>"
echo "$svg" > /tmp/circle.svg

echo "$col" | wl-copy

notify-send -i "/tmp/circle.svg" -a "Colorpicker" "$col was successfully copied to your clipboard."
