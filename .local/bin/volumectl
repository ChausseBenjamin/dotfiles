#!/bin/bash

case "$1" in
mute) pactl set-sink-mute @DEFAULT_SINK@ toggle ;;
*)
	pcnt="$1"
	sign="$2"
	if [ -z "$sign" ]; then
		pactl set-sink-volume @DEFAULT_SINK@ "$pcnt%"
	else
		curr=$(pactl get-sink-volume @DEFAULT_SINK@ | grep -oP '\d+(?=%)' | head -1)
		case "$sign" in
			+) new=$((curr + pcnt)); [ "$new" -gt 100 ] && new=100 ;;
			-) new=$((curr - pcnt)); [ "$new" -lt 0 ] && new=0 ;;
		esac
		pactl set-sink-volume @DEFAULT_SINK@ "${new}%"
	fi
	;;
esac

vol=$(pactl get-sink-volume @DEFAULT_SINK@ | grep -oP '\d+(?=%)' | head -1)
muted=$(pactl get-sink-mute @DEFAULT_SINK@)
notify_data="${vol}%"; [ "$muted" = "Mute: yes" ] && notify_data+=" (muted)"
# notify-send.sh -t 1000 --replace-file /tmp/vol-notif -a "$notify_data"
