#!/bin/sh
case "$1" in
    ca)       mmsg dispatch setkeymode,0 ;;
    us)       mmsg dispatch setkeymode,1 ;;
    coolmak)  mmsg dispatch setkeymode,2 ;;
    "")       mmsg dispatch switch_keyboard_layout ;;
    *)        echo "usage: layouttoggle [ca|us|coolmak]" && exit 1 ;;
esac

# Restart waybar if running
pidof waybar >/dev/null 2>&1 && kill -38 "$(pidof waybar)" 2>/dev/null || true
