#!/bin/sh

# Usage:
# This script prints network status with appropriate icons
# Checks ethernet first, then WiFi via wpa_supplicant
#
# Icons:
# ůįąÄ  Ethernet connected
# ůį§ģ  WiFi/wpa_supplicant disabled
# ůį§Į  No WiFi connection
# ůį§ü  WiFi strength low (0-25%)
# ůį§Ę  WiFi strength mid (26-50%)
# ůį§•  WiFi strength high (51-75%)
# ůį§®  WiFi strength max (76-100%)

[ -n "$1" ] && {
	prompt="Ôáę  Network:"

  restart="ůįź• Restart Wpa Supplicant"
  start="ÔĀč Start Wpa Supplicant"
  stop="ÔĀć Stop Wpa Supplicant"
	edit_cfg="ÓąŹ Edit configurationt"
	options="$start\n$stop\n$restart\n$edit_cfg"

	choice=$(echo -e "$options"| tofi --width="20%" --height="10%" --prompt-text "$prompt")
	case "$choice" in
		"$start") sudo rc-service wpa_supplicant start && exit 0 ;;
		"$stop") sudo rc-service wpa_supplicant stop ;;
		"$restart")
				sudo rc-service wpa_supplicant stop && sleep 1 && \
				sudo rc-service wpa_supplicant start && exit 0 ;;
		"$edit_cfg")
			$TERMINAL --title="wpa_supplicant" \
				        --command="$EDITOR /etc/wpa_supplicant/wpa_supplicant.conf" && \
				sudo rc-service wpa_supplicant stop && sleep 1 && \
				sudo rc-service wpa_supplicant start && exit 0 ;;
		*) exit 1;
	esac

}

# Check if ethernet is connected
for eth in /sys/class/net/e*; do
    [ -d "$eth" ] && [ "$(cat "$eth/operstate" 2>/dev/null)" = "up" ] && {
        printf '{ "text": "ůįąÄ ", "class": "block" }\n'
        exit 0
    }
done

# Check wpa_supplicant status
wpa_status=$(wpa_cli -i wlan0 status 2>/dev/null)
[ $? -ne 0 ] && {
    printf '{ "text": "ůį§ģ ", "class": "block" }\n'
    exit 0
}

# Check if connected to WiFi
echo "$wpa_status" | grep -q "wpa_state=COMPLETED" || {
    printf '{ "text": "ůį§Į ", "class": "block" }\n'
    exit 0
}

# Get network name (SSID)
ssid=$(echo "$wpa_status" | grep "^ssid=" | cut -d= -f2)
# Decode escape sequences (e.g., \xc3\xa9 -> √©)
ssid=$(printf '%b' "$ssid")
[ -z "$ssid" ] && ssid="Unknown"

# Get signal strength
signal=$(wpa_cli -i wlan0 signal_poll 2>/dev/null | grep "^RSSI=" | cut -d= -f2)
[ -z "$signal" ] && signal=-100

# Convert RSSI to approximate percentage (rough estimation)
# RSSI ranges typically from -30 (excellent) to -90 (poor)
if [ "$signal" -ge -50 ]; then
    icon="ůį§®"  # max strength
elif [ "$signal" -ge -60 ]; then
    icon="ůį§•"  # high strength
elif [ "$signal" -ge -70 ]; then
    icon="ůį§Ę"  # mid strength
else
    icon="ůį§ü"  # low strength
fi

printf '{ "text": "%s %s", "class": "block" }\n' "$icon" "$ssid"
